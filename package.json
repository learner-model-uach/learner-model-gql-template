{
  "name": "learner-model-gql-template",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "concurrently -m 1 -r \"graphql-codegen --config codegen.yaml\" \"next build\"",
    "dev": "concurrently -r next pnpm:gql:watch pnpm:open:browser",
    "gql": "graphql-codegen --config codegen.yaml",
    "gql:watch": "graphql-codegen --config codegen.yaml --watch",
    "open:browser": "wait-on -s 1 http://localhost:3000 && open-cli http://localhost:3000",
    "pretty": "prettier --write \"**/*.{ts,tsx,json}\"",
    "start": "next start"
  },
  "dependencies": {
    "@auth0/auth0-react": "^1.12.1",
    "@chakra-ui/react": "^1.8.9",
    "@chakra-ui/system": "^1.12.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/core": "^6.1.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "framer-motion": "^6.5.1",
    "graphql": "^16.14.2",
    "next": "^16.2.9",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-icons": "^5.4.0",
    "react-query": "^3.39.3",
    "rq-gql": "^0.4.3",
    "serialize-error": "^13.0.1",
    "valtio": "1.2.9"
  },
  "devDependencies": {
    "@graphql-codegen/schema-ast": "^6.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^17.0.93",
    "@types/react-dom": "^17.0.26",
    "concurrently": "^10.0.3",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.4",
    "typescript": "^4.9.5",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "pnpm": ">=9.15.9"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/core"
      ],
      "allowedVersions": {
        "graphql": "*",
        "framer-motion": "*"
      }
    }
  }
}
